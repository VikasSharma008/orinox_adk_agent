# ─── Google Cloud Authentication ──────────────────────────────────────────────
# ADC (preferred): on Cloud Run the attached service account is used automatically.
# For local dev: set GOOGLE_APPLICATION_CREDENTIALS or use gcloud auth application-default login
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

PROJECT_ID=orinox-wealth-copilot
SA_EMAIL=orinox-sa@orinox-wealth-copilot.iam.gserviceaccount.com

# Model names — change here to switch versions without touching code
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004

# Fallback: API key (local dev only, not recommended for production)
# GOOGLE_API_KEY=your-gemini-api-key

# ─── Database ───
USE_SQLITE=true
SQLITE_PATH=orinox_dev.db
ALLOYDB_HOST=
ALLOYDB_PORT=5432
ALLOYDB_USER=postgres
ALLOYDB_PASSWORD=
ALLOYDB_DATABASE=orinox

# ─── MCP Servers (toggle on/off) ───
MCP_FETCH_ENABLED=true
MCP_MEMORY_ENABLED=true
MCP_FILESYSTEM_ENABLED=true
MCP_FS_ROOT=/tmp/orinox_output

# ─── App ───
PORT=8080
LOG_LEVEL=info
ENVIRONMENT=development
